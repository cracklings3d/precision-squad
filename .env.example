# Copy this file to .env and fill in local values.

# GitHub PAT used by precision-squad for issue reads and optional publishing.
GITHUB_TOKEN=

# Optional provider configuration for local opencode agent runs.
OPENAI_KEY=
OPENAI_API_BASE_URL=

# Optional default model for local opencode repair/review runs.
# precision-squad uses this automatically when no --repair-model/--review-model flag is passed.
# Use a full provider/model identifier if your opencode setup requires one.
CUSTOM_OPENAI_MODEL_NAME=gpt-5.4
